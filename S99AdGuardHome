#!/bin/sh
which renice >/dev/null 2>&1 && renice -10 $$ >/dev/null 2>&1
ENABLED="yes"
WORK_DIR="/opt/etc/AdGuardHome"
LOG_FILE="syslog"
PID_FILE="/opt/var/run/AdGuardHome.pid"
PROCS="AdGuardHome"
GOGC="40"
CPU_COUNT=""
if which grep >/dev/null 2>&1; then
	CPU_COUNT="$(grep -c '^processor' /proc/cpuinfo 2>/dev/null)"
fi
case "${CPU_COUNT}" in
	"4") GOMAXPROCS="2" ;;
	*) GOMAXPROCS="1" ;;
esac
MEMORY_LIMIT_MIB=""
if which awk >/dev/null 2>&1; then
	MEMORY_LIMIT_MIB="$(awk -v PROCS="${GOMAXPROCS}" '
		$1 == "MemAvailable:" { available = $2 }
		$1 == "MemFree:" { free = $2 }
		$1 == "Buffers:" { buffers = $2 }
		$1 == "Cached:" { cached = $2 }
		END {
			if (!available) available = free + buffers + cached
			limit = int((available * 0.9537 / 1024) / PROCS)
			if (limit >= 1) print limit
		}
	' /proc/meminfo 2>/dev/null)"
fi
case "${MEMORY_LIMIT_MIB}" in
	"" | *[!0-9]*) MEMORY_LIMIT_MIB="128" ;;
esac
GOMEMLIMIT="${MEMORY_LIMIT_MIB}MiB"
ARGS="-s run -c ${WORK_DIR}/AdGuardHome.yaml -w ${WORK_DIR} --pidfile ${PID_FILE} --no-check-update -l ${LOG_FILE}"
PREARGS="env TZ=/etc/localtime GOGC=${GOGC} GOMAXPROCS=${GOMAXPROCS} GOMEMLIMIT=${GOMEMLIMIT} QUIC_GO_DISABLE_ECN=true"

# Functions are grouped by purpose; names are sorted alpha-numerically within each group.

# DNS handoff helpers

dns_handoff_dependencies_available() {
	for _dns_command in awk kill netstat pidof service sleep; do
		if ! which "${_dns_command}" >/dev/null 2>&1; then
			if which logger >/dev/null 2>&1; then
				logger -st "${PROCS}" "Required DNS handoff command is unavailable: ${_dns_command}"
			else
				printf '%s\n' "${PROCS}: required DNS handoff command is unavailable: ${_dns_command}" >&2
			fi
			return 1
		fi
	done
	return 0
}

dns_retry_limit() {
	case "$1" in
		"" | *[!0-9]*) printf '%s\n' "$2" ;;
		*) printf '%s\n' "$1" ;;
	esac
}

adguardhome_owns_dns() {
	_dns_socket_table=""
	pidof "${PROCS}" >/dev/null 2>&1 || return 1
	_dns_socket_table="$(netstat -nlp 2>/dev/null)" || return 1
	printf '%s\n' "${_dns_socket_table}" | awk -v proc="${PROCS}" '
		$0 ~ /^(tcp)6?[[:space:]]+/ && $0 ~ /:53[[:space:]]/ {
			if ($0 ~ "/" proc "([[:space:]]|$)") tcp_found=1; else other_found=1
		}
		$0 ~ /^(udp)6?[[:space:]]+/ && $0 ~ /:53[[:space:]]/ {
			if ($0 ~ "/" proc "([[:space:]]|$)") udp_found=1; else other_found=1
		}
		END { exit(tcp_found && udp_found && !other_found ? 0 : 1) }
	'
}

kill_dns_port_owners() {
	_dns_socket_table="$(netstat -nlp 2>/dev/null)" || return 1
	_dns_pids="$(printf '%s\n' "${_dns_socket_table}" | awk -v proc="${PROCS}" '
		$0 ~ /^(tcp)6?[[:space:]]+/ && $0 ~ /:53[[:space:]]/ && $0 !~ "/" proc "([[:space:]]|$)" {
			split($7, pid_parts, "/")
			if (pid_parts[1] ~ /^[0-9]+$/ && !seen[pid_parts[1]]++) printf "%s ", pid_parts[1]
		}
		$0 ~ /^(udp)6?[[:space:]]+/ && $0 ~ /:53[[:space:]]/ && $0 !~ "/" proc "([[:space:]]|$)" {
			split($6, pid_parts, "/")
			if (pid_parts[1] ~ /^[0-9]+$/ && !seen[pid_parts[1]]++) printf "%s ", pid_parts[1]
		}
	')"
	[ -n "${_dns_pids}" ] && kill -s 9 ${_dns_pids} 2>/dev/null
}

dns_port_available() {
	_dns_socket_table="$(netstat -nlp 2>/dev/null)" || return 1
	printf '%s\n' "${_dns_socket_table}" | awk -v proc="${PROCS}" '
		$0 ~ /^(tcp|udp)6?[[:space:]]+/ && $0 ~ /:53[[:space:]]/ && $0 !~ "/" proc "([[:space:]]|$)" { unavailable = 1 }
		END { exit(unavailable ? 1 : 0) }
	'
}

stop_dns_port_guard() {
	[ -n "${ADGUARDHOME_DNS_GUARD_PID:-}" ] || return 0
	kill "${ADGUARDHOME_DNS_GUARD_PID}" >/dev/null 2>&1
	wait "${ADGUARDHOME_DNS_GUARD_PID}" 2>/dev/null
	unset ADGUARDHOME_DNS_GUARD_PID
	return 0
}

wait_for_adguardhome_dns() {
	_dns_wait_attempts="0"
	_dns_wait_limit="$(dns_retry_limit "${ADGUARDHOME_DNS_WAIT_RETRIES:-}" 10)"
	while [ "${_dns_wait_attempts}" -lt "${_dns_wait_limit}" ]; do
		adguardhome_owns_dns && return 0
		_dns_wait_attempts="$((_dns_wait_attempts + 1))"
		sleep 1s
	done
	adguardhome_owns_dns
}

guard_dns_port_for_adguardhome() {
	_dns_guard_attempts="0"
	_dns_guard_limit="$(dns_retry_limit "${ADGUARDHOME_DNS_GUARD_RETRIES:-}" 10)"
	while [ "${_dns_guard_attempts}" -lt "${_dns_guard_limit}" ]; do
		adguardhome_owns_dns && break
		service stop_dnsmasq >/dev/null 2>&1
		kill_dns_port_owners
		_dns_guard_attempts="$((_dns_guard_attempts + 1))"
		sleep 1s
	done
	# Remain a live child until stop_dns_port_guard terminates and reaps us.  This
	# prevents the saved PID from being reused while the parent verifies DNS.
	trap 'exit 0' HUP INT TERM
	while :; do
		sleep 1s
	done
}

# Service hook helpers

post_start_adguardhome() {
	if ! wait_for_adguardhome_dns; then
		stop_dns_port_guard
		logger -st "${PROCS}" "AdGuardHome did not acquire TCP and UDP port 53; startup will be rolled back."
		return 1
	fi
	stop_dns_port_guard
	if [ "${ADGUARDHOME_SKIP_DNSMASQ_RESTART:-}" != "1" ]; then
		service restart_dnsmasq >/dev/null 2>&1 || return 1
	fi
	return 0
}

post_start_failure_adguardhome() {
	stop_dns_port_guard
	[ "${ADGUARDHOME_SKIP_DNSMASQ_RESTART:-}" = "1" ] && return 0
	service restart_dnsmasq >/dev/null 2>&1
}

pre_start_adguardhome() {
	_dns_stop_attempts="0"
	_dns_stop_limit="$(dns_retry_limit "${ADGUARDHOME_DNSMASQ_STOP_RETRIES:-}" 10)"
	dns_handoff_dependencies_available || return 1
	ulimit -v 1750000 2>/dev/null || true
	ulimit -m 450000 2>/dev/null || true
	ulimit -s 8192 2>/dev/null || true
	if [ "$(pidof syslog-ng logrotate | wc -w)" -gt 0 ] && which scribe >/dev/null 2>&1; then
		scribe restart
	fi
	while [ "${_dns_stop_attempts}" -lt "${_dns_stop_limit}" ]; do
		service stop_dnsmasq >/dev/null 2>&1
		kill_dns_port_owners
		_dns_stop_attempts="$((_dns_stop_attempts + 1))"
		sleep 1s
		if dns_port_available; then
			guard_dns_port_for_adguardhome >/dev/null 2>&1 &
			ADGUARDHOME_DNS_GUARD_PID="$!"
			return 0
		fi
	done
	logger -st "${PROCS}" "Unable to release port 53 after ${_dns_stop_limit} attempt(s); startup aborted."
	post_start_failure_adguardhome
	return 1
}

PRECMD="pre_start_adguardhome"
POSTCMD="post_start_adguardhome"
POSTFAILCMD="post_start_failure_adguardhome"
DESC="${PROCS}"
PATH="/opt/sbin:/opt/bin:/opt/usr/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
TZ="$(sed -n '1p' /etc/TZ 2>/dev/null)"
export TZ
[ -z "${SCRIPT_LOC}" ] && . /jffs/addons/AdGuardHome.d/AdGuardHome.sh
