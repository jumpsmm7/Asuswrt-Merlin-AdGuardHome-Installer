adguardhome_yaml_remove_ipset_file() {
	local has_ipset tmp_file yaml_target
	yaml_target="${1:-${YAML_FILE}}"
	[ -f "${yaml_target}" ] || return 0
	has_ipset="$(awk '
		function indentation(line,    text) { text = line; sub(/[^[:space:]].*$/, "", text); return length(text) }
		/^(dns|\047dns\047|"dns"):[[:space:]]*(&[^][{},[:space:]]+[[:space:]]*)?(#.*)?$/ { in_dns = 1; next }
		in_dns && /^[^[:space:]]/ { exit }
		in_dns && /^[[:space:]]*($|#)/ { next }
		in_dns && !child_indent { child_indent = indentation($0) }
		in_dns && indentation($0) == child_indent && substr($0, child_indent + 1) ~ /^(ipset|ipset_file|\047ipset\047|\047ipset_file\047|"ipset"|"ipset_file"):[[:space:]]*/ { print "1"; exit }
	' "${yaml_target}")" || return 1
	[ "${has_ipset}" = "1" ] || return 0
	chmod 600 "${yaml_target}" || return 1
	tmp_file="${yaml_target}.ipset.$$"
	cp -p "${yaml_target}" "${tmp_file}" || return 1
	awk '
		function indentation(line,    text) { text = line; sub(/[^[:space:]].*$/, "", text); return length(text) }
		function block_marker(value) {
			gsub(/^[[:space:]]+|[[:space:]]+$/, "", value)
			return value ~ /^[>|]([+-]|[+-]?[1-9]|[1-9][+-]?)?([[:space:]]+#.*)?$/
		}
		/^(dns|\047dns\047|"dns"):[[:space:]]*(&[^][{},[:space:]]+[[:space:]]*)?(#.*)?$/ { in_dns = 1; print; next }
		in_dns && /^[^[:space:]]/ { in_dns = 0 }
		in_dns && skip_block && /^[[:space:]]*($|#)/ { next }
		in_dns && skip_block && indentation($0) > skip_indent { next }
		in_dns && skip_block && indentation($0) == skip_indent && substr($0, skip_indent + 1) ~ /^-[[:space:]]/ { next }
		in_dns && skip_block { skip_block = 0 }
		in_dns && /^[[:space:]]*($|#)/ { print; next }
		in_dns && !child_indent { child_indent = indentation($0) }
		in_dns && indentation($0) == child_indent && substr($0, child_indent + 1) ~ /^(ipset|\047ipset\047|"ipset"):[[:space:]]*/ {
			print substr($0, 1, child_indent) "ipset: []"
			skip_block = 1
			skip_indent = child_indent
			next
		}
		in_dns && indentation($0) == child_indent && substr($0, child_indent + 1) ~ /^(ipset_file|\047ipset_file\047|"ipset_file"):[[:space:]]*/ {
			value = substr($0, child_indent + 1)
			sub(/^(ipset_file|\047ipset_file\047|"ipset_file"):[[:space:]]*/, "", value)
			if (block_marker(value)) {
				skip_block = 1
				skip_indent = child_indent
			}
			next
		}
		{ print }
	' "${yaml_target}" >"${tmp_file}" && adguardhome_yaml_secure_file "${tmp_file}" && mv -f "${tmp_file}" "${yaml_target}" && adguardhome_yaml_secure_file "${yaml_target}" || {
		rm -f "${tmp_file}"
		return 1
	}
}

